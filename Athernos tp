    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 10)
    local strokeN = Instance.new("UIStroke", notif)
    strokeN.Color = Color3.fromRGB(255,255,255)
    strokeN.Thickness = 1
    strokeN.Transparency = 0.5
    local text = Instance.new("TextLabel", notif)
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.Text = msg
    text.TextColor3 = Color3.new(1,1,1)
    text.TextScaled = true
    text.Font = Enum.Font.Gotham
    notif.Position = UDim2.new(1, 0, 0, 0)
    TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 0, 0, 0)}):Play()
    for _, child in pairs(notifContainer:GetChildren()) do
        if child ~= notif then
            TweenService:Create(child, TweenInfo.new(0.2), {Position = UDim2.new(0, 0, child.Position.Y.Offset - 45, 0)}):Play()
        end
    end
    if isTimer then
        local timerLabel = Instance.new("TextLabel", notif)
        timerLabel.Size = UDim2.new(0.3, 0, 1, 0)
        timerLabel.Position = UDim2.new(0.7, 0, 0, 0)
        timerLabel.BackgroundTransparency = 1
        timerLabel.Text = "15s"
        timerLabel.TextColor3 = Color3.fromRGB(255,200,0)
        timerLabel.TextScaled = true
        timerLabel.Font = Enum.Font.GothamBold
        timerLabel.TextXAlignment = Enum.TextXAlignment.Right
        local remaining = 15
        task.spawn(function()
            while remaining > 0 and notif and notif.Parent do
                task.wait(1)
                remaining = remaining - 1
                if timerLabel then timerLabel.Text = remaining .. "s" end
            end
        end)
    end
    task.wait(duration or 2)
    TweenService:Create(notif, TweenInfo.new(0.2), {BackgroundTransparency = 1, Position = UDim2.new(1, 0, notif.Position.Y.Offset, 0)}):Play()
    task.wait(0.3)
    notif:Destroy()
end

