-- Funciones de flotar
local floatBV = nil

local function enableFloat()
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    if not hrp or not humanoid then return end
    if floatBV then floatBV:Destroy() end
    floatBV = Instance.new("BodyVelocity")
    floatBV.Velocity = Vector3.new(0,0,0)
    floatBV.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    floatBV.Parent = hrp
    humanoid.PlatformStand = true
end

local function disableFloat()
    if floatBV then
        floatBV:Destroy()
        floatBV = nil
    end
    local char = Player.Character
    if char then
        local humanoid = char:FindFirstChildWhichIsA("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

-- Noclip simple forzado (bucle cada 0.1s)
local noclipActive = false
local noclipTask = nil

local function forceNoClip()
    local char = Player.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
end

local function enableNoclip()
    if noclipActive then return end
    noclipActive = true
    noclipTask = task.spawn(function()
        while noclipActive do
            forceNoClip()
            task.wait(0.1)
        end
    end)
end

local function disableNoclip()
    noclipActive = false
    if noclipTask then
        task.cancel(noclipTask)
        noclipTask = nil
    end
    local char = Player.Character
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

--// TP ABEL - PARTE 3/3: AUTO FARM (CORREGIDO: ESPERA 1s ANTES DE PROMPTS)
local autoFarmActive = false
local autoFarmLoopTask = nil
local originalSellState = false
local originalLaundryState = false
local originalGrabState = false
local autoFarmToggleFrame = nil

-- Cooldowns (5 segundos)
local lastLaundryAuto = 0
local lastSellAuto = 0
local promptCooldown = 0.5

local function startAutoFarm()
    if autoFarmActive then return end
    autoFarmActive = true
    _G.AutoFarmRunning = true

    -- Guardar estados originales
    originalSellState = _G.AutoSell
    originalLaundryState = _G.AutoLaundry
    originalGrabState = _G.AutoGrab

    -- Desactivar AutoSell, AutoLaundry y AutoGrab temporalmente
    if _G.AutoSell then
        _G.AutoSell = false
        for _, v in pairs(miscPage:GetDescendants()) do
            if v:IsA("Frame") and v.Parent and v.Parent:IsA("Frame") then
                local holder = v.Parent
                if holder and holder:FindFirstChild("TextLabel") and holder.TextLabel.Text == "Auto Sell" then
                    local circle = v:FindFirstChild("Frame")
                    if circle then
                        circle.Position = UDim2.new(0,2,0.5,-10)
                        v.BackgroundColor3 = Color3.fromRGB(40,40,40)
                    end
                end
            end
        end
    end
    if _G.AutoLaundry then
        _G.AutoLaundry = false
        for _, v in pairs(miscPage:GetDescendants()) do
            if v:IsA("Frame") and v.Parent and v.Parent:IsA("Frame") then
                local holder = v.Parent
                if holder and holder:FindFirstChild("TextLabel") and holder.TextLabel.Text == "Auto Laundry" then
                    local circle = v:FindFirstChild("Frame")
                    if circle then
                        circle.Position = UDim2.new(0,2,0.5,-10)
                        v.BackgroundColor3 = Color3.fromRGB(40,40,40)
                    end
                end
            end
        end
    end
    if _G.AutoGrab then
        _G.AutoGrab = false
        for _, v in pairs(miscPage:GetDescendants()) do
            if v:IsA("Frame") and v.Parent and v.Parent:IsA("Frame") then
                local holder = v.Parent
                if holder and holder:FindFirstChild("TextLabel") and holder.TextLabel.Text == "Auto Grab Materiales" then
                    local circle = v:FindFirstChild("Frame")
                    if circle then
                        circle.Position = UDim2.new(0,2,0.5,-10)
                        v.BackgroundColor3 = Color3.fromRGB(40,40,40)
                    end
                end
            end
        end
    end

    -- Notificación inicial y cuenta regresiva
    showNotification("🔥 Auto Farm activado en 3 segundos...", 1)
    for i = 3, 1, -1 do
        showNotification(i .. "...", 1)
        task.wait(1)
    end

    -- Activar modo fantasma
    setInvisible(true)
    enableFloat()
    enableNoclip()

    -- Bucle infinito
    autoFarmLoopTask = task.spawn(function()
        while autoFarmActive do
            -- ========== PROCESO CLEAR ==========
            spam(clear, 14, 0.4)          -- invisible
            setInvisible(false)            -- visible
            spam(clear, 9, 0.1)          -- visible
            
            -- *** ESPERA 1 SEGUNDO PARA QUE EL PROMPT APAREZCA ***
            task.wait(1)                  -- <--- NUEVA ESPERA

            -- Activar Laundry Dirty Money (solo si visible y cooldown)
            local now = tick()
            if isCharacterVisible() and now - lastLaundryAuto >= promptCooldown then
                if firePrompt("Laundry Dirty Money") then
                    lastLaundryAuto = now
                end
            end

            -- Ráfaga de compras (siempre visible)
            for i = 1, 3 do firePrompt("Buy Fake Watch"); task.wait(0.7) end
            task.wait(1)
            for i = 1, 3 do firePrompt("Buy Fake Designer Bag"); task.wait(0.7) end
            task.wait(1)
            for i = 1, 4 do firePrompt("Buy Sarsaparilla"); task.wait(0.7) end

            -- ========== PROCESO SELL ==========
            spam(sell, 9, 0.4)           -- invisible
            setInvisible(false)            -- visible
            spam(sell, 19, 0.1)           -- visible
            
            -- *** ESPERA 1 SEGUNDO PARA QUE EL PROMPT APAREZCA ***
            task.wait(0.6)                  -- <--- NUEVA ESPERA

            -- Activar Sell All Smuggle (solo si visible y cooldown)
            now = tick()
            if isCharacterVisible() and now - lastSellAuto >= promptCooldown then
                if firePrompt("Sell All Smuggle") then
                    lastSellAuto = now
                end
            end

            task.wait(0.5)   -- pequeña pausa antes de repetir el ciclo
        end
    end)
end

-- Función para detener el Auto Farm y restaurar todo
local function stopAutoFarm()
    if not autoFarmActive then return end
    autoFarmActive = false
    _G.AutoFarmRunning = false

    if autoFarmLoopTask then
        task.cancel(autoFarmLoopTask)
        autoFarmLoopTask = nil
    end

    -- Desactivar en orden: noclip -> flotar -> invisible
    disableNoclip()
    disableFloat()
    setInvisible(false)

    -- Restaurar toggles originales
    if originalSellState then
        _G.AutoSell = true
        for _, v in pairs(miscPage:GetDescendants()) do
            if v:IsA("Frame") and v.Parent and v.Parent:IsA("Frame") then
                local holder = v.Parent
                if holder and holder:FindFirstChild("TextLabel") and holder.TextLabel.Text == "Auto Sell" then
                    local circle = v:FindFirstChild("Frame")
                    if circle then
                        circle.Position = UDim2.new(1,-22,0.5,-10)
                        v.BackgroundColor3 = Color3.fromRGB(0,200,100)
                    end
                end
            end
        end
    end
    if originalLaundryState then
        _G.AutoLaundry = true
        for _, v in pairs(miscPage:GetDescendants()) do
            if v:IsA("Frame") and v.Parent and v.Parent:IsA("Frame") then
                local holder = v.Parent
                if holder and holder:FindFirstChild("TextLabel") and holder.TextLabel.Text == "Auto Laundry" then
                    local circle = v:FindFirstChild("Frame")
                    if circle then
                        circle.Position = UDim2.new(1,-22,0.5,-10)
                        v.BackgroundColor3 = Color3.fromRGB(0,200,100)
                    end
                end
            end
        end
    end
    if originalGrabState then
        _G.AutoGrab = true
        for _, v in pairs(miscPage:GetDescendants()) do
            if v:IsA("Frame") and v.Parent and v.Parent:IsA("Frame") then
                local holder = v.Parent
                if holder and holder:FindFirstChild("TextLabel") and holder.TextLabel.Text == "Auto Grab Materiales" then
                    local circle = v:FindFirstChild("Frame")
                    if circle then
                        circle.Position = UDim2.new(1,-22,0.5,-10)
                        v.BackgroundColor3 = Color3.fromRGB(0,200,100)
                    end
                end
            end
        end
    end

    showNotification("❌ Auto Farm desactivado", 1)
end

-- Vincular el toggle "Auto Farm" en la pestaña Main (corregida posición)
local function fixMainToggles()
    for _, v in pairs(mainPage:GetDescendants()) do
        if v:IsA("Frame") and v.Parent and v.Parent:IsA("Frame") then
            local holder = v.Parent
            if holder and holder:FindFirstChild("TextLabel") then
                local label = holder.TextLabel.Text
                if label == "Auto Farm" then
                    autoFarmToggleFrame = v
                    v.InputBegan:Connect(function(input)
                        if input.UserInputType.Name:find("Mouse") or input.UserInputType.Name == "Touch" then
                            local newState = not _G.AutoFarm
                            _G.AutoFarm = newState
                            if newState then
                                startAutoFarm()
                            else
                                stopAutoFarm()
                            end
                            local circle = v:FindFirstChild("Frame")
                            if circle then
                                if newState then
                                    v.BackgroundColor3 = Color3.fromRGB(0,200,100)
                                    circle:TweenPosition(UDim2.new(1,-22,0.5,-10),"Out","Quad",0.2,true)
                                else
                                    v.BackgroundColor3 = Color3.fromRGB(40,40,40)
                                    circle:TweenPosition(UDim2.new(0,2,0.5,-10),"Out","Quad",0.2,true)
                                end
                            end
                        end
                    end)
                end
            end
        end
    end
end

fixMainToggles()

