local currentSeat = nil
local invisTransparency = 0.7

local function setCharacterTransparency(trans)
    local char = Player.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Transparency = trans
        end
    end
end

-- Invisibilidad (actualiza _G.invisActive)
local function setInvisible(state)
    local char = Player.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    if not root or not torso then return false end
    if state and not _G.invisActive then
        setCharacterTransparency(invisTransparency)
        local savedPos = root.CFrame
        char:MoveTo(root.Position + Vector3.new(0, 20, 0))
        task.wait(0.05)
        local seat = Instance.new("Seat")
        seat.Name = "InvisSeat"
        seat.Transparency = 1
        seat.CanCollide = false
        seat.Anchored = false
        seat.Parent = workspace
        local weld = Instance.new("Weld")
        weld.Part0 = seat
        weld.Part1 = torso
        weld.Parent = seat
        seat.CFrame = savedPos
        currentSeat = seat
        _G.invisActive = true
        return true
    elseif not state and _G.invisActive then
        setCharacterTransparency(0)
        if currentSeat and currentSeat.Parent then
            currentSeat:Destroy()
            currentSeat = nil
        end
        _G.invisActive = false
        return true
    end
    return false
end

