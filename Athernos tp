-- Función para crear toggles (switch) con altura reducida para Misc
local function CreateToggle(parent, text, pos, callback, isMisc)
    local height = (isMisc and 35) or 40
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(0.9,0,0,height)
    holder.Position = pos
    holder.BackgroundTransparency = 1
    local label = Instance.new("TextLabel", holder)
    label.Size = UDim2.new(0.7,0,1,0)
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    local toggle = Instance.new("Frame", holder)
    toggle.Size = UDim2.new(0,50,0,24)
    toggle.Position = UDim2.new(0.8,0,0.5,-12)
    toggle.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(1,0)
    local circle = Instance.new("Frame", toggle)
    circle.Size = UDim2.new(0,20,0,20)
    circle.Position = UDim2.new(0,2,0.5,-10)
    circle.BackgroundColor3 = Color3.fromRGB(200,200,200)
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1,0)
    local state = false
    local function update()
        if state then
            toggle.BackgroundColor3 = Color3.fromRGB(0,200,100)
            circle:TweenPosition(UDim2.new(1,-22,0.5,-10),"Out","Quad",0.2,true)
        else
            toggle.BackgroundColor3 = Color3.fromRGB(40,40,40)
            circle:TweenPosition(UDim2.new(0,2,0.5,-10),"Out","Quad",0.2,true)
        end
        callback(state)
    end
    toggle.InputBegan:Connect(function(input)
        if input.UserInputType.Name:find("Mouse") or input.UserInputType.Name == "Touch" then
            state = not state
            update()
        end
    end)
    return { setState = function(s) state = s; update() end }
end

